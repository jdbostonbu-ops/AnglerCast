// AnglerCast Prisma schema.
// Entity with a relationship: one User has many SavedSpots; each SavedSpot belongs to one User.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {          // Columns are below
  id                        String     @id @default(cuid()) // Primary Key. My primary key is a cuid — a random, non-sequential ID. Per OWASP, that's defense-in-depth: it mitigates enumeration and avoids leaking record counts
  email                     String     @unique
  profileName               String?
  profileImageUrl           String?
  passwordHash              String
  isVerified                Boolean    @default(false)
  verificationCodeHash      String?
  verificationCodeExpiresAt DateTime?
  passwordResetCodeHash      String?
  passwordResetCodeExpiresAt DateTime?
  createdAt                 DateTime   @default(now())

  savedSpots                SavedSpot[]
  catchReports              CatchReport[]
}

model SavedSpot {     // Columns are below
  id        String   @id @default(cuid()) // Primary key
  userId    String   // Foreign key 
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name      String
  // Coordinates stored at full precision — never truncated/rounded.
  latitude  Float
  longitude Float
  species   String
  waterType String   // "freshwater" | "saltwater"
  notes     String?
  createdAt DateTime @default(now())

  @@index([userId])
}

model CatchReport {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  waterType String   // "freshwater" | "saltwater"
  body      String
  createdAt DateTime @default(now())

  @@index([userId])
}